 1 REM PRECISION TIMER PROGRAM
20 PRINT "INPUT THE NUMBER OF EVENTS."
25 PRINT "THIS NUMBER MUST BE LESS THAN 65537."
30 INPUT N
35 N = N - 1
36 REM POKE N INTO TWO LOCATIONS.
40 NHI = INT (N / 256)
45 POKE 26,NHI
50 NLO = (N / 256 - NHI) * 256
55 POKE 25, NLO
56 REM SET UP JUMP VECTOR.
60 POKE 10,76: POKE 11 12: POKE 12,25
64 REM CALL PRECISION TIMER SUB ROUTINE.
65 Z = USR (0)
69 REM CONVERT NUMBER OF CLOCK CYCLES FROM HEXADECIMAL TO DECIMAL.
70 A = PEEK (27)
75 B = 256 * PEEK (28) + A
80 C = 65536 * PEEK (29) + B
81 C = C / 1022714
82 REM CLOCK FREQUENCY = 1.022714 MHZ.
85 D = (16777216 / 1022714) * PEEK (30)
90 T = D + C
100 PERIOD = T / (N +1)
110 F = 1 / PERIOD
120 PRINT "THE PERIOD IS";PERIOD;" SECONDS."
130 PRINT "THE FREQUENCY IS";F;" HERTZ."
140 GOTO 65
