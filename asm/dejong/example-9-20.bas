  1 REM TEMPERATURE MEASUREMENT
 20 PRINT "INPUT THE NUMBER OF EVENTS."
 25 PRINT "THIS NUMBER MUST BE LESS THAN 65537."
 30 INPUT N
 35 N = N - 1
 40 NHI = INT (N / 256)
 45 POKE 26,NHI
 50 NLO = (N / 256 - NHI) * 256
 55 POKE 25,NLO
 60 POKE 10,76: POKE 11,12: POKE 12,25
 65 Z = USR (0)
 70 A = PEEK (27)
 75 B = 256 * PEEK (29) + B
 80 C = 65536 * PEEK (29) + B
 81 C = C / 1022714
 85 D = (16777216 / 1022714) * PEEK (30)
 90 T = D + C
100 PERIOD = T / (N + 1)
110 F = 1 / PERIOD
120 F = 9 / 5 * (F - 273.1) + 32
130 PRINT INT (F + .5);" DEGREES FAHRENHEIT."
140 GOTO 65
